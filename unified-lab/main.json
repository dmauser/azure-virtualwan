          "deployErGateway": false,
          "deployFirewall": false,
          "firewallSku": "Standard",
          "enableRoutingIntent": false,
          "routingIntentMode": "PrivateOnly"
        }
      ],
      "metadata": {
        "description": "Hub configurations array — add entries for multi-hub"
      }
    },
    "spokes": {
      "type": "array",
